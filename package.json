{
  "name": "quark-mini-assistant",
  "version": "0.1.0",
  "description": "夸克PC桌面端Mini知识助手 — AI网盘文件分析与问答",
  "main": "dist-electron/main.js",
  "scripts": {
    "dev": "concurrently -k \"npm run dev:vite\" \"npm run dev:electron-wait\"",
    "dev:vite": "vite",
    "dev:electron-compile": "tsc -p tsconfig.node.json",
    "dev:electron-watch": "tsc -p tsconfig.node.json --watch --preserveWatchOutput",
    "dev:electron-wait": "wait-on http://localhost:5173 && cross-env NODE_ENV=development electron .",
    "dev:all": "concurrently -k \"npm run dev:vite\" \"npm run dev:electron-watch\" \"npm run dev:electron-wait\"",
    "build": "npm run dev:electron-compile && vite build && electron-builder",
    "build:vite": "tsc && vite build"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^4.3.0",
    "adm-zip": "^0.5.17",
    "concurrently": "^9.1.0",
    "cross-env": "^7.0.3",
    "electron": "^33.2.1",
    "electron-builder": "^25.1.0",
    "typescript": "^5.7.0",
    "vite": "^6.0.0",
    "wait-on": "^8.0.0"
  },
  "dependencies": {
    "dotenv": "^17.4.2",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "zustand": "^5.0.0"
  }
}
